extends ../layouts/base.pug

block content
  include ../partials/alert.pug

  .d-flex.align-items-center.gap-2.mb-3
    a.btn.btn-ghost(href="/post")
      i.bi.bi-arrow-left
    p.label-section.mb-0 — publicación

  //- ── CASO 1: Una sola imagen
  if post.Images && post.Images.length === 1
    - const image = post.Images[0]
    - const ratings = image.Ratings || []
    - const total = ratings.length
    - const avg = total > 0 ? (ratings.reduce((a, r) => a + r.value, 0) / total).toFixed(1) : null

    .card.mb-4
      img.w-100(
        src=`/post/${post.id}/image/${image.id}`
        alt=post.title
        style="max-height:580px;object-fit:contain;background:var(--bg)"
      )
      .card-body

        //- Usuario + título
        .d-flex.align-items-center.justify-content-between.pb-3.mb-3(style="border-bottom:1px solid var(--border)")
          .d-flex.align-items-center.gap-2
            .avatar.avatar-xs= post.User.username[0].toUpperCase()
            a(href=`/profile/${post.User.id}` style="font-weight:600;color:var(--text);text-decoration:none;font-size:13px")
              = post.User.username
          h6.mb-0(style="font-size:13px;color:var(--text);font-family:'Playfair Display',serif")= post.title

        //- Valoraciones
        .d-flex.align-items-center.justify-content-between.pb-3.mb-3(style="border-bottom:1px solid var(--border)")
          .d-flex.align-items-center.gap-2#promedioUnico
            if avg
              span.badge.badge-rating ⭐ #{avg}
              span(style="font-size:11px;color:var(--dim)") #{total} votacion#{total !== 1 ? 'es' : ''}
            else
              span(style="font-size:12px;color:var(--dim)") sin valoraciones
          if user && user.id !== post.User.id
            if userRatings && userRatings[image.id]
              span.badge.badge-rating tu voto: #{userRatings[image.id]} ⭐
            else
              form(method="POST" action="/rating/rate" novalidate)
                input(type="hidden" name="imageId" value=image.id)
                input(type="hidden" name="postId" value=post.id)
                .star-rating
                  button.star(type="button" name="value" value="1") ★
                  button.star(type="button" name="value" value="2") ★
                  button.star(type="button" name="value" value="3") ★
                  button.star(type="button" name="value" value="4") ★
                  button.star(type="button" name="value" value="5") ★

        //- Toggle comentarios (solo autor) — usa fetch
        if user && user.id === post.User.id
          - const estadoUnico = image.activeComments ? 'abierto' : 'cerrado'
          button.btn.btn-outline.btn-sm.mb-3.btnToggleComentarios(
            type="button"
            data-image-id=image.id
            data-post-id=post.id
            data-estado=estadoUnico
            style="font-size:11px"
          )
            if image.activeComments
              i.bi.bi-lock.me-1
              | cerrar comentarios
            else
              i.bi.bi-unlock.me-1
              | abrir comentarios

        //- Comentarios inline
        .d-flex.flex-column(style="border:1px solid var(--border);border-radius:var(--r);overflow:hidden;margin-top:4px")
          .flex-grow-1.overflow-auto.p-3(style="max-height:280px;min-height:60px")
            p.label-section.mb-2 — comentarios
            if !image.activeComments
              p(style="font-size:12px;color:var(--dim);font-style:italic") los comentarios están cerrados.
            else if image.Comments && image.Comments.length > 0
              each comment in image.Comments
                .d-flex.gap-2.mb-3
                  .avatar.avatar-xs= comment.User ? comment.User.username[0].toUpperCase() : '?'
                  .flex-grow-1
                    .comment-bubble
                      strong(style="font-size:11px;color:var(--amber)")
                        = comment.User ? comment.User.username : 'usuario'
                      p.mb-0(style="font-size:12px;color:var(--text)")= comment.body
                    if user && (user.id === post.User.id || user.id === comment.user_id)
                      button.btn.btn-ghost.text-danger.btnEliminarComentario(
                        type="button"
                        data-comment-id=comment.id
                        style="font-size:11px;padding:2px 6px"
                      ) eliminar
            else if image.activeComments
              p(style="font-size:12px;color:var(--dim)") todavía no hay comentarios.
          if image.activeComments
            .p-3(style="border-top:1px solid var(--border)")
              if user
                form#formComentario(
                  data-image-id=image.id
                  data-post-id=post.id
                  data-inicial=user.username[0].toUpperCase()
                )
                  .d-flex.gap-2.align-items-center
                    .avatar.avatar-xs= user.username[0].toUpperCase()
                    .input-group
                      input#inputComentario.form-control(
                        type="text"
                        placeholder="comentar..."
                        style="border-radius:20px 0 0 20px;font-size:12px"
                      )
                      button.btn.btn-amber(type="submit" style="border-radius:0 20px 20px 0;padding:0 14px")
                        i.bi.bi-send-fill
              else
                p.mb-0(style="font-size:12px;color:var(--dim);text-align:center")
                  a(href="/auth/login" style="color:var(--amber)") iniciá sesión
                  |  para comentar.

  //- ── CASO 2: Múltiples imágenes → carrusel
  else if post.Images && post.Images.length > 1
    .card.mb-4
      #carouselPost.carousel.slide(data-bs-ride="false")
        .carousel-indicators
          each image, i in post.Images
            button(
              type="button"
              data-bs-target="#carouselPost"
              data-bs-slide-to=i
              class=i === 0 ? 'active' : ''
              style="background:var(--amber);width:6px;height:6px;border-radius:50%;border:none"
            )
        .carousel-inner(style="background:var(--bg)")
          each image, i in post.Images
            .carousel-item(class=i === 0 ? 'active' : '')
              img.d-block.w-100(
                src=`/post/${post.id}/image/${image.id}`
                alt=post.title
                style="max-height:580px;object-fit:contain;cursor:pointer"
                data-bs-toggle="modal"
                data-bs-target=`#modalImagen${image.id}`
              )
        button.carousel-control-prev(type="button" data-bs-target="#carouselPost" data-bs-slide="prev")
          span.carousel-control-prev-icon
        button.carousel-control-next(type="button" data-bs-target="#carouselPost" data-bs-slide="next")
          span.carousel-control-next-icon
      .card-body
        .d-flex.align-items-center.justify-content-between.pb-3.mb-2(style="border-bottom:1px solid var(--border)")
          .d-flex.align-items-center.gap-2
            .avatar.avatar-xs= post.User.username[0].toUpperCase()
            a(href=`/profile/${post.User.id}` style="font-weight:600;color:var(--text);text-decoration:none;font-size:13px")
              = post.User.username
          h6.mb-0(style="font-size:13px;color:var(--text);font-family:'Playfair Display',serif")= post.title
        p.text-center.mb-0(style="font-size:11px;color:var(--dim)")
          i.bi.bi-cursor.me-1
          | hacé click en la imagen para comentar y valorar

  //- Info adicional
  if post.description || (post.Labels && post.Labels.length > 0) || (user && user.id === post.User.id)
    .card.mb-4
      .card-body
        if post.description
          p.mb-3(style="font-size:13px;color:var(--muted);line-height:1.6")= post.description
        if post.Labels && post.Labels.length > 0
          .mb-2
            each label in post.Labels
              span.badge.badge-label.me-1.mb-1= label.name
        if user && user.id === post.User.id
          hr
          form(
            method="POST"
            action=`/post/${post.id}/delete`
            onsubmit="return confirm('¿seguro que querés eliminar esta publicación?')"
          )
            button.btn.btn-danger(type="submit")
              i.bi.bi-trash.me-2
              | eliminar publicación

  //- ══════════ MODALES ══════════
  if post.Images && post.Images.length > 1
    each image, idx in post.Images
      - const ratings = image.Ratings || []
      - const total = ratings.length
      - const avg = total > 0 ? (ratings.reduce((a, r) => a + r.value, 0) / total).toFixed(1) : null
      - const estadoModal = image.activeComments ? 'abierto' : 'cerrado'

      .modal.fade(id=`modalImagen${image.id}` tabindex="-1")
        .modal-dialog.modal-xl.modal-dialog-centered
          .modal-content
            .modal-header(style="padding:12px 20px")
              .d-flex.align-items-center.justify-content-between.w-100.me-3
                .d-flex.align-items-center.gap-2
                  .avatar.avatar-xs= post.User.username[0].toUpperCase()
                  a(href=`/profile/${post.User.id}` style="font-weight:600;color:var(--text);text-decoration:none;font-size:13px")
                    = post.User.username
                div
                  h6.modal-title.mb-0= post.title
                  small(style="font-size:11px;color:var(--dim)") foto #{idx + 1} de #{post.Images.length}
              button.btn-close(type="button" data-bs-dismiss="modal")

            .modal-body.p-0
              .row.g-0
                //- Imagen
                .col-lg-7(style="background:var(--bg);display:flex;align-items:center;justify-content:center;min-height:400px")
                  img(
                    src=`/post/${post.id}/image/${image.id}`
                    alt=post.title
                    style="max-width:100%;max-height:70vh;object-fit:contain;display:block;padding:12px"
                  )

                //- Panel derecho
                .col-lg-5(style="border-left:1px solid var(--border);display:flex;flex-direction:column;max-height:70vh")

                  //- Valoraciones + toggle
                  .p-3(style="border-bottom:1px solid var(--border)")
                    .d-flex.align-items-center.justify-content-between.mb-2
                      .d-flex.align-items-center.gap-2(id=`promedio${image.id}`)
                        if avg
                          span.badge.badge-rating ⭐ #{avg}
                          span(style="font-size:11px;color:var(--dim)") #{total} votacion#{total !== 1 ? 'es' : ''}
                        else
                          span(style="font-size:12px;color:var(--dim)") sin valoraciones
                      if user && user.id !== post.User.id
                        if userRatings && userRatings[image.id]
                          span.badge.badge-rating tu voto: #{userRatings[image.id]} ⭐
                        else
                          form(method="POST" action="/rating/rate")
                            input(type="hidden" name="imageId" value=image.id)
                            input(type="hidden" name="postId" value=post.id)
                            .star-rating
                              button.star(type="button" name="value" value="1") ★
                              button.star(type="button" name="value" value="2") ★
                              button.star(type="button" name="value" value="3") ★
                              button.star(type="button" name="value" value="4") ★
                              button.star(type="button" name="value" value="5") ★

                    //- Toggle comentarios — usa fetch
                    if user && user.id === post.User.id
                      button.btn.btn-outline.btn-sm.w-100.btnToggleComentarios(
                        type="button"
                        data-image-id=image.id
                        data-post-id=post.id
                        data-estado=estadoModal
                        style="font-size:11px"
                      )
                        if image.activeComments
                          i.bi.bi-lock.me-1
                          | cerrar comentarios
                        else
                          i.bi.bi-unlock.me-1
                          | abrir comentarios

                  //- Lista comentarios
                  .flex-grow-1.overflow-auto.p-3(style="max-height:300px")
                    p.label-section.mb-2 — comentarios
                    if !image.activeComments
                      p(style="font-size:12px;color:var(--dim);font-style:italic") los comentarios están cerrados.
                    else if image.Comments && image.Comments.length > 0
                      each comment in image.Comments
                        .d-flex.gap-2.mb-3
                          .avatar.avatar-xs= comment.User ? comment.User.username[0].toUpperCase() : '?'
                          .flex-grow-1
                            .comment-bubble
                              strong(style="font-size:11px;color:var(--amber)")
                                = comment.User ? comment.User.username : 'usuario'
                              p.mb-0(style="font-size:12px;color:var(--text)")= comment.body
                            if user && (user.id === post.User.id || user.id === comment.user_id)
                              button.btn.btn-ghost.text-danger.btnEliminarComentario(
                                type="button"
                                data-comment-id=comment.id
                                style="font-size:11px;padding:2px 6px"
                              ) eliminar
                    else
                      p(style="font-size:12px;color:var(--dim)") todavía no hay comentarios.

                  //- Input comentario
                  if image.activeComments && user
                    .p-3(style="border-top:1px solid var(--border)")
                      form(
                        data-image-id=image.id
                        data-post-id=post.id
                        data-modal=`modalImagen${image.id}`
                        data-inicial=user.username[0].toUpperCase()
                        class="formComentarioModal"
                      )
                        .d-flex.gap-2.align-items-center
                          .avatar.avatar-xs= user.username[0].toUpperCase()
                          .input-group
                            input.form-control.inputComentarioModal(
                              type="text"
                              placeholder="comentar..."
                              style="border-radius:20px 0 0 20px;font-size:12px"
                            )
                            button.btn.btn-amber(type="submit" style="border-radius:0 20px 20px 0;padding:0 14px")
                              i.bi.bi-send-fill
                  else if !user && image.activeComments
                    .p-3(style="border-top:1px solid var(--border)")
                      p.mb-0(style="font-size:12px;color:var(--dim);text-align:center")
                        a(href="/auth/login" style="color:var(--amber)") iniciá sesión
                        |  para comentar.