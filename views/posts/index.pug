extends ../layouts/base.pug

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.section-title
      i.bi.bi-grid-fill.me-2
      | Publicaciones
    a.btn.btn-primary(href="/post/create")
      i.bi.bi-plus-lg.me-1
      | Nueva publicación

  include ../partials/alert.pug

  if !posts || posts.length === 0
    .card.text-center.py-5
      .card-body
        i.bi.bi-camera.display-4.text-muted
        p.mt-3.text-muted Todavía no hay publicaciones.
  else
    .row.g-4
      each post in posts
        .col-sm-6.col-md-4
          include ../partials/post-card.pug