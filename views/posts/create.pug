extends ../layouts/base.pug

block content
  .row.justify-content-center
    .col-lg-7

      p.label-section — nueva publicación
      h2.mb-4(style="font-size:1.5rem") subir foto

      include ../partials/alert.pug

      .card
        .card-body

          form(method="POST" action="/post/create" enctype="multipart/form-data")

            .mb-4
              label.form-label título *
              input.form-control(type="text" name="title" placeholder="un título descriptivo" required)

            .mb-4
              label.form-label descripción
              textarea.form-control(name="description" rows="3" placeholder="contá algo sobre esta foto (opcional)")

            .mb-4
              label.form-label etiquetas
              input.form-control(type="text" name="labels" placeholder="naturaleza, ciudad, retrato (separadas por coma)")
              .form-text separalas con comas.

            .mb-4
              label.form-label imágenes *
              input.form-control(type="file" name="images" multiple accept="image/*" required)
              .form-text podés subir varias a la vez. máx. 10mb por imagen.

            //- Copyright con modal de ayuda
            .mb-4(style="background:var(--bg-hover);border:1px solid var(--border);border-radius:var(--r);padding:16px")
              .form-check.mb-2
                input.form-check-input#copyrightCheck(type="checkbox" name="copyright" value="true")
                label.form-check-label(for="copyrightCheck")
                  i.bi.bi-shield-lock.me-1(style="color:var(--amber)")
                  | proteger con copyright
              #copyrightTextDiv(style="display:none")
                input.form-control.form-control(type="text" name="copyrightText" placeholder="© tu nombre 2025")
                .form-text texto que aparecerá como marca de agua en la imagen.

            button.btn.btn-amber.w-100.py-2(type="submit")
              i.bi.bi-cloud-upload.me-2
              | publicar

  script.
    const check = document.getElementById('copyrightCheck')
    const div = document.getElementById('copyrightTextDiv')
    check.addEventListener('change', () => {
      div.style.display = check.checked ? 'block' : 'none'
    })