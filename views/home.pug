extends layouts/base.pug

block content
  if user
    .d-flex.justify-content-between.align-items-center.mb-4
      div
        p.label-section — feed reciente
        h2.mb-0(style="font-size:1.5rem") inicio
      a.btn.btn-amber(href="/post/create")
        i.bi.bi-plus.me-1
        | publicar

    if !posts || posts.length === 0
      .card.text-center.py-5
        .card-body
          i.bi.bi-camera(style="font-size:2.5rem;color:var(--dim)")
          p.mt-3(style="color:var(--muted)") todavía no hay publicaciones.
          a.btn.btn-amber.mt-2(href="/post/create") subir primera foto
    else
      .feed-grid
        each post in posts
          .feed-item
            include partials/post-card.pug

  else
    .landing-wrap
      .container.py-5
        .row.align-items-center.g-5
          .col-lg-6
            p.label-section — Bienvenido
            .landing-logo Fotaza
              span(style="color:var(--text);font-weight:400") App
            p.landing-tagline.mt-3 compartí tus fotos,#[br]descubrí el mundo.
            p.mt-3(style="font-size:13px;color:var(--dim);line-height:1.8")
              | Deja que tu lente hable, en la comunidad que conecta la vida a través de las fotos.
            .d-flex.gap-3.mt-4.flex-wrap
              a.btn.btn-amber.px-4(href="/auth/login")
                i.bi.bi-box-arrow-in-right.me-2
                | iniciar sesión
              a.btn.btn-outline.px-4(href="/explorar")
                i.bi.bi-globe2.me-2
                | explorar fotos

          .col-lg-5.offset-lg-1
            .landing-card
              p.label-section.mb-3 — crear cuenta
              form(method="POST" action="/auth/register")
                .mb-3
                  .row.g-2
                    .col-6
                      input.form-control(type="text" name="firstname" placeholder="nombre" required)
                    .col-6
                      input.form-control(type="text" name="lastname" placeholder="apellido" required)
                .mb-3
                  input.form-control(type="text" name="username" placeholder="nombre de usuario" required)
                .mb-3
                  input.form-control(type="email" name="email" placeholder="email" required)
                .mb-3
                  input.form-control(type="password" name="password" placeholder="contraseña (mín. 6 caracteres)" required minlength="6")
                button.btn.btn-amber.w-100.py-2(type="submit") registrarse