extends layouts/base.pug

block content
  if user
    //- Feed para usuarios logueados
    .d-flex.justify-content-between.align-items-center.mb-4
      h2.section-title
        i.bi.bi-images.me-2
        | Publicaciones recientes
      a.btn.btn-primary(href="/post/create")
        i.bi.bi-plus-lg.me-1
        | Nueva publicación

    if !posts || posts.length === 0
      .card.text-center.py-5
        .card-body
          i.bi.bi-camera.display-4.text-muted
          p.mt-3.text-muted Todavía no hay publicaciones. ¡Sé el primero en subir una!
          a.btn.btn-primary(href="/post/create") Subir foto
    else
      .row.g-4
        each post in posts
          .col-sm-6.col-md-4
            include partials/post-card.pug

  else
    //- Landing para usuarios no logueados
    .landing-hero
      .container
        .row.align-items-center.min-vh-75
          .col-lg-6.mb-5.mb-lg-0
            .landing-logo
              i.bi.bi-camera-fill.me-2
              | Fotaza
            p.landing-tagline Compartí tus fotos con el mundo.
            p.text-muted.mt-3.fs-5
              | Una comunidad donde podés subir, descubrir y conectar
              | a través de la fotografía.

          .col-lg-5.offset-lg-1
            .landing-card
              h4.fw-bold.text-center.mb-4 Crear cuenta nueva
              form(method="POST" action="/auth/register")
                .mb-3
                  input.form-control.form-control-lg(
                    type="text"
                    name="firstname"
                    placeholder="Nombre"
                    required
                  )
                .mb-3
                  input.form-control.form-control-lg(
                    type="text"
                    name="lastname"
                    placeholder="Apellido"
                    required
                  )
                .mb-3
                  input.form-control.form-control-lg(
                    type="text"
                    name="username"
                    placeholder="Nombre de usuario"
                    required
                  )
                .mb-3
                  input.form-control.form-control-lg(
                    type="email"
                    name="email"
                    placeholder="Email"
                    required
                  )
                .mb-3
                  input.form-control.form-control-lg(
                    type="password"
                    name="password"
                    placeholder="Contraseña (mín. 6 caracteres)"
                    required
                    minlength="6"
                  )
                button.btn.btn-success.w-100.btn-lg.fw-bold(type="submit") Registrarse

              hr.my-4
              a.btn.btn-primary.w-100.btn-lg.fw-bold(href="/auth/login") Iniciar sesión