nav.navbar.navbar-expand-lg
  .container
    a.navbar-brand(href="/")
      | foto
      span za
    button.navbar-toggler(
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#menu"
    )
      i.bi.bi-list(style="font-size:1.3rem;color:var(--text-muted)")
    #menu.collapse.navbar-collapse
      ul.navbar-nav.me-auto.mb-2.mb-lg-0
        li.nav-item
          a.nav-link(href="/")
            i.bi.bi-house.me-1
            | inicio
        li.nav-item
          a.nav-link(href="/post")
            i.bi.bi-grid.me-1
            | galería
        li.nav-item
          a.nav-link(href="/search")
            i.bi.bi-search.me-1
            | buscar
      ul.navbar-nav.align-items-center.gap-2
        li.nav-item
          a.btn.btn-primary.btn-sm.px-3(href="/post/create")
            i.bi.bi-plus.me-1
            | publicar
        li.nav-item.dropdown
          a.nav-link.dropdown-toggle.d-flex.align-items-center.gap-2(
            href="#"
            data-bs-toggle="dropdown"
          )
            .avatar.avatar-sm= user.firstname[0].toUpperCase()
            span.d-none.d-lg-inline(style="font-size:13px;color:var(--text-muted)")
              = user.username
          ul.dropdown-menu.dropdown-menu-end
            li
              a.dropdown-item(href=`/profile/${user.id}`)
                i.bi.bi-person.me-2
                | mi perfil
            li
              hr.dropdown-divider
            li
              a.dropdown-item.text-danger(href="/auth/logout")
                i.bi.bi-box-arrow-right.me-2
                | salir