nav.navbar.navbar-expand-lg
  .container
    a.navbar-brand(href="/")
      i.bi.bi-camera-fill.me-1
      | Fotaza
    button.navbar-toggler(
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#menu"
      style="border:none"
    )
      span.navbar-toggler-icon
    #menu.collapse.navbar-collapse
      ul.navbar-nav.me-auto.mb-2.mb-lg-0
        li.nav-item
          a.nav-link(href="/")
            i.bi.bi-house-fill.me-1
            | Inicio
        li.nav-item
          a.nav-link(href="/post")
            i.bi.bi-grid-fill.me-1
            | Publicaciones
        li.nav-item
          a.nav-link(href="/search")
            i.bi.bi-search.me-1
            | Buscar
      ul.navbar-nav.align-items-center.gap-2
        li.nav-item
          a.btn.btn-primary.btn-sm.px-3(href="/post/create")
            i.bi.bi-plus-lg.me-1
            | Publicar
        li.nav-item.dropdown
          a.nav-link.dropdown-toggle.d-flex.align-items-center.gap-2(
            href="#"
            data-bs-toggle="dropdown"
          )
            .rounded-circle.bg-primary.d-flex.align-items-center.justify-content-center(
              style="width:34px;height:34px;color:white;font-weight:700;font-size:.85rem"
            )= user.firstname[0].toUpperCase()
            span.d-none.d-lg-inline= user.username
          ul.dropdown-menu.dropdown-menu-end.shadow-sm(style="border-radius:12px;border:1px solid #dddfe2")
            li
              a.dropdown-item.py-2(href=`/profile/${user.id}`)
                i.bi.bi-person-fill.me-2
                | Mi perfil
            li
              hr.dropdown-divider.my-1
            li
              a.dropdown-item.py-2.text-danger(href="/auth/logout")
                i.bi.bi-box-arrow-right.me-2
                | Salir