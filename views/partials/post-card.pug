.card.h-100.d-flex.flex-column
  if post.Images && post.Images.length > 0
    img.post-img(
      src=`/post/${post.id}/image/${post.Images[0].id}`
      alt=post.title
      loading="lazy"
    )
  else
    .post-placeholder
      i.bi.bi-image
  .post-card-body.d-flex.flex-column.flex-grow-1
    p.post-card-title= post.title
    .mb-2(style="min-height:1.4rem")
      if post.Labels && post.Labels.length > 0
        each label in post.Labels
          span.badge.badge-label.me-1= label.name
    .flex-grow-1
      if post.description
        p(style="font-size:11px;color:var(--dim);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;margin:0")
          = post.description
    .post-card-footer.mt-auto
      small(style="font-size:11px;color:var(--dim)")
        i.bi.bi-person.me-1
        if post.User
          a(href=`/profile/${post.User.id}` style="color:var(--muted);text-decoration:none")
            = post.User.username
        else
          span Desconocido
      a.btn.btn-outline(href=`/post/${post.id}` style="font-size:11px;padding:4px 12px")
        i.bi.bi-eye.me-1
        | Ver