doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title FotazaApp
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500&display=swap")
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css")
    link(rel="stylesheet" href="/css/style.css")

  body
    if user
      .topbar
        a.topbar-brand(href="/") Fotaza
          span App
        .d-flex.align-items-center.gap-2
          button.btn.btn-ghost#sidebarToggle
            i.bi.bi-list(style="font-size:1.3rem")

      aside.sidebar#sidebar
        .sidebar-brand
          a(href="/") Fotaza
            span App

        nav.sidebar-nav
          a.sidebar-link(href="/")
            i.bi.bi-house
            | Inicio
          a.sidebar-link(href="/post")
            i.bi.bi-grid
            | Galería
          a.sidebar-link(href="/search")
            i.bi.bi-search
            | Buscar
          hr(style="border-color:var(--border);margin:8px 12px")
          a.sidebar-link(href="/post/create")
            i.bi.bi-plus-circle
            | Nueva Publicacion
          a.sidebar-link(href=`/profile/${user.id}`)
            i.bi.bi-person
            | Mi perfil

        .sidebar-footer
          a.sidebar-user(href=`/profile/${user.id}`)
            .avatar.avatar-sm= user.username[0].toUpperCase()
            div
              .sidebar-user-name= user.username
          a.sidebar-link.mt-2(href="/auth/logout" style="color:var(--red)")
            i.bi.bi-box-arrow-right
            | salir

      main.main-content
        block content

    else
      block content

    footer
      small © 2026 FotazaApp — Comunidad de Fotografía
    
  script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
  script(src="/js/baseLayout.js")
  script(src="/js/postShow.js")
  script(src="/js/postCreate.js")