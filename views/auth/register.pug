extends ../layouts/base.pug

block content
  .landing-wrap
    .container
      .row.justify-content-center
        .col-md-6.col-lg-5
          .text-center.mb-4
            a(href="/" style="text-decoration:none")
              .landing-logo(style="font-size:3rem") foto
                span(style="color:var(--text);font-weight:400") za
            p.mt-2(style="font-size:10px;color:var(--dim);letter-spacing:2px;text-transform:uppercase") crear cuenta nueva

          .landing-card
            include ../partials/alert.pug

            p.label-section.mb-3 — tus datos

            form(method="POST" action="/auth/register")
              .mb-3
                .row.g-2
                  .col-6
                    input.form-control(type="text" name="firstname" placeholder="nombre" required)
                  .col-6
                    input.form-control(type="text" name="lastname" placeholder="apellido" required)
              .mb-3
                input.form-control(type="text" name="username" placeholder="nombre de usuario" required)
              .mb-3
                input.form-control(type="email" name="email" placeholder="email" required)
              .mb-3
                input.form-control(type="password" name="password" placeholder="contraseña (mín. 6 caracteres)" required minlength="6")
              .mb-3
                small(style="font-size:11px;color:var(--dim)")
                  | al registrarte aceptás las normas de la comunidad.
              button.btn.btn-amber.w-100.py-2(type="submit")
                i.bi.bi-person-plus.me-2
                | crear cuenta

            hr
            .text-center
              p.mb-2(style="font-size:12px;color:var(--dim)") ¿ya tenés cuenta?
              a.btn.btn-outline.w-100(href="/auth/login") iniciar sesión