extends ../layouts/base.pug

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    div
      p.label-section — búsqueda
      h2.mb-0(style="font-size:1.5rem") buscar

  //- Formulario
  .card.mb-4
    .card-body
      form(method="GET" action="/search")
        .row.g-2
          .col-md-4
            input.form-control(
              type="text"
              name="q"
              placeholder="título o descripción"
              value=query.q || ''
              autocomplete="off"
            )
          .col-md-3
            input.form-control(
              type="text"
              name="label"
              placeholder="etiqueta"
              value=query.label || ''
              autocomplete="off"
            )
          .col-md-3
            input.form-control(
              type="text"
              name="username"
              placeholder="usuario"
              value=query.username || ''
              autocomplete="off"
            )
          .col-md-2
            button.btn.btn-amber.w-100(type="submit")
              i.bi.bi-search.me-1
              | buscar

  include ../partials/alert.pug

  //- Resultados de usuarios
  if usuarios && usuarios.length > 0
    p.label-section.mb-3 — usuarios encontrados
    .row.g-3.mb-4
      each u in usuarios
        .col-6.col-md-4.col-lg-3
          a.card.text-decoration-none(href=`/profile/${u.id}` style="transition:border-color .2s")
            .card-body.d-flex.align-items-center.gap-3.p-3
              .avatar.avatar-sm= u.username[0].toUpperCase()
              div
                p.mb-0(style="font-size:13px;font-weight:600;color:var(--text)")= u.username
                p.mb-0(style="font-size:11px;color:var(--dim)")= u.firstname || ''

  //- Resultados de publicaciones
  if posts && posts.length > 0
    p.label-section.mb-3 — publicaciones encontradas
    p.mb-3(style="font-size:11px;color:var(--dim)")
      = posts.length + ' resultado' + (posts.length !== 1 ? 's' : '')
    .feed-grid
      each post in posts
        .feed-item
          include ../partials/post-card.pug

  //- Sin resultados
  if (!posts || posts.length === 0) && (!usuarios || usuarios.length === 0)
    .card.text-center.py-5
      .card-body
        i.bi.bi-search(style="font-size:2.5rem;color:var(--dim)")
        p.mt-3(style="color:var(--muted)")
          if query.q || query.label || query.username
            | no se encontraron resultados con esos criterios.
          else
            | usá el buscador para encontrar fotos o usuarios.